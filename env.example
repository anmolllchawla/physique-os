# PhysiqueOS — environment variables.
# Copy this file to .env.local for local dev, or set these in your Vercel
# project settings. The app works fully WITHOUT any of these (local-only mode);
# they unlock optional cloud backup and the AI coach.

# ── AI Coach (DeepSeek) ────────────────────────────────
# Required only to enable the /coach page. Get a key at platform.deepseek.com.
# This key is used SERVER-SIDE ONLY (in /api/agent) and is never exposed to the
# browser. Do NOT prefix it with NEXT_PUBLIC_.
DEEPSEEK_API_KEY=
# Optional overrides:
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── GitHub data sync (optional cloud backup) ───────────
# Fine-grained PAT with "Contents: Read and write" on a PRIVATE data repo.
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_PATH=physiqueos-backup.json
